# Copy to .env and adjust. .env is gitignored (holds credentials).
USERNAME=admin
PASSWORD=admin
CONFIG_PASSWORD=admin
DEBUG_MODE=false
BROKER_HOST=localhost
BROKER_PORT=1883
BROKER_USERNAME=admin
BROKER_PASSWORD=password
DATABASE_URL=postgresql+asyncpg://hbot:hummingbot-api@localhost:5432/hummingbot_api
GATEWAY_URL=http://localhost:15888
GATEWAY_PASSPHRASE=admin

# IMPORTANT: absolute HOST path of THIS repo root (the folder that contains bots/).
# The API uses it to bind-mount this folder into every bot instance it deploys.
# Must match where you cloned the repo — e.g. C:/Users/<you>/Documents/terminal/my-trading
BOTS_PATH=C:/Users/melmdim/Documents/terminal/my-trading
