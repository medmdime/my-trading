# Copy to .env and adjust. Server-side vars (no VITE_ prefix) never reach the browser.

# Where the Vite proxy forwards /api and /ws. Prod default; use a local stack for a sandbox.
API_TARGET=https://api.stylette.info
API_USER=admin
API_PASS=admin

# Browser-exposed.
VITE_API_BASE=/api
VITE_WS_BASE=/ws
VITE_TARGET_LABEL=LIVE PROD · api.stylette.info
VITE_ENV=prod
