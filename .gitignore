# --- secrets / env ---
.env

# --- exchange API keys (never commit) ---
bots/credentials/*/connectors/*
!bots/credentials/*/connectors/.gitignore
!bots/credentials/*/connectors/.dockerignore

# --- runtime state generated by the engine (not my code) ---
bots/archived/*
bots/instances/*
bots/logs/
bots/data/
!bots/**/.gitignore

# --- python junk ---
__pycache__/
*.pyc

# --- backtest/optimization outputs ---
*_results.csv
*_result.json
*_trials.json
